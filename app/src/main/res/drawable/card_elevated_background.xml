<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="@color/outline" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="0dp">
        <shape>
            <solid android:color="@color/surface" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>