<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true"
    android:overScrollMode="never">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="42dp"
        android:paddingBottom="28dp">

        <!-- APP LOGO CONTAINER -->

        <FrameLayout
            android:id="@+id/logoParent"
            android:layout_width="170dp"
            android:layout_height="170dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Glow -->

            <View
                android:layout_width="170dp"
                android:layout_height="170dp"
                android:alpha="0.08"
                android:background="@drawable/splash_background"/>

            <!-- Card -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:layout_gravity="center"
                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                app:cardCornerRadius="38dp"
                app:cardElevation="4dp">

                <ImageView
                    android:id="@+id/lr_imageView1"
                    android:layout_width="82dp"
                    android:layout_height="82dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/icon_app"/>

            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

        <!-- HEADING -->

        <TextView
            android:id="@+id/lr_textView1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:fontFamily="@font/poppins_bold"
            android:text="Let's Connect 🚖"
            android:textColor="?attr/colorOnSurface"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/logoParent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- SUBTITLE -->

        <TextView
            android:id="@+id/lr_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/poppins_regular"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="Find trusted travel companions\nand share rides easily across cities"
            android:textAlignment="center"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/lr_textView1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- LOGIN CARD -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/buttonCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
            app:cardCornerRadius="32dp"
            app:cardElevation="1dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/lr_subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <!-- LOGIN BUTTON -->

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/lr_btn_login"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="Login"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app:backgroundTint="?attr/colorPrimary"
                    app:cornerRadius="20dp"
                    app:elevation="2dp"
                    app:iconGravity="textEnd"
                    app:iconPadding="10dp"
                    app:iconTint="?attr/colorOnPrimary"
                    app:rippleColor="?attr/colorPrimaryContainer"
                    android:textColor="@color/primary"/>

                <!-- OR -->

                <TextView
                    android:id="@+id/lr_textView2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="18dp"
                    android:fontFamily="@font/poppins_medium"
                    android:text="OR"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="13sp"/>

                <!-- REGISTER BUTTON -->

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/lr_btn_register"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="18dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="Create Account"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    app:cornerRadius="20dp"
                    app:icon="@drawable/ic_edit"
                    app:iconGravity="textStart"
                    app:iconPadding="10dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- FEATURE CARD -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/featureCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="?attr/colorSurfaceContainer"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/buttonCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="18dp">

                <ImageView
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:src="@drawable/ic_verified"
                    app:tint="?attr/colorPrimary"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="Safe &amp; Verified Rides"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="15sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="Connect with trusted drivers and passengers"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="13sp"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- DEVELOPER -->

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/featureCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/develop_by_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:text="Developed by"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/developer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="Shelu Pandey"
                android:textColor="?attr/colorPrimary"
                android:textSize="15sp"/>

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>