<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:paddingHorizontal="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="20dp">

    <!-- Back Button - Reduced Size -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/backCard"
        android:layout_width="44dp"
        android:layout_height="44dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="0.5dp">

        <ImageView
            android:id="@+id/l_back"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Back"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="?attr/colorOnSurface" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Logo - Reduced Size -->
    <FrameLayout
        android:id="@+id/logoParent"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/backCard">


        <com.google.android.material.card.MaterialCardView
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:layout_gravity="center"
            app:cardBackgroundColor="?attr/colorPrimaryContainer"
            app:cardCornerRadius="26dp"
            app:cardElevation="2dp">

            <ImageView
                android:id="@+id/l_icon"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:src="@drawable/icon_app"
                tools:ignore="ContentDescription" />

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <!-- Heading - Reduced Size -->
    <TextView
        android:id="@+id/l_textView1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:fontFamily="@font/poppins_bold"
        android:text="Welcome Back 👋"
        android:textColor="?attr/colorOnSurface"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/logoParent" />

    <!-- Subtitle - Reduced Size -->
    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/poppins_regular"
        android:text="Sign in to access your account"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/l_textView1" />

    <!-- Login Card - Reduced Padding -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/loginCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="0.5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <!-- Mobile Field - Reduced Size -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/l_mobile_layout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Mobile Number"
                app:boxBackgroundColor="?attr/colorSurface"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeWidth="0.5dp"
                app:boxStrokeWidthFocused="1.5dp"
                app:hintTextColor="?attr/colorOnSurfaceVariant">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/l_mobile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:inputType="phone"
                    android:maxLength="10"
                    android:paddingVertical="14dp"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password Field - Reduced Size -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/l_password_layout"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="Password"
                app:boxBackgroundColor="?attr/colorSurface"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:boxStrokeWidth="0.5dp"
                app:boxStrokeWidthFocused="1.5dp"
                app:endIconMode="password_toggle"
                app:hintTextColor="?attr/colorOnSurfaceVariant">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/l_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:inputType="textPassword"
                    android:paddingVertical="14dp"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="14sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Forgot Password - Compact -->
            <TextView
                android:id="@+id/txtForgot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/poppins_medium"
                android:text="Forgot Password?"
                android:textColor="?attr/colorPrimary"
                android:textSize="12sp" />

            <!-- Login Button - Reduced Height -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sign_in"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="Log In"
                android:textAllCaps="false"
                android:textSize="15sp"
                app:backgroundTint="?attr/colorPrimary"
                app:cornerRadius="16dp"
                app:elevation="0dp"
                app:iconGravity="textEnd"
                app:iconPadding="8dp"
                app:iconTint="?attr/colorOnPrimary"
                app:rippleColor="?attr/colorPrimaryContainer"
                android:textColor="?attr/colorOnPrimary" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Sign Up Section - Compact -->
    <LinearLayout
        android:id="@+id/signup_prompt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/loginCard">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_regular"
            android:text="Don't have an account? "
            android:textColor="@color/background"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/l_sign_Up"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_semibold"
            android:text="Sign Up"
            android:textColor="@color/background"
            android:textSize="13sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>