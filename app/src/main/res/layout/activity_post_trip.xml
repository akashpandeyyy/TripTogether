<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <!-- Main Scroll -->

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="30dp">

            <!-- Header -->

            <LinearLayout
                android:id="@+id/headerLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    app:cardBackgroundColor="?attr/colorPrimaryContainer"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_route"
                        app:tint="?attr/colorPrimary"/>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/post_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_bold"
                        android:text="Post a Ride"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="28sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="Share your ride &amp; earn money"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="14sp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Main Card -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mainCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="?attr/colorSurfaceContainerLow"
                app:cardCornerRadius="30dp"
                app:cardElevation="2dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerLayout"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <!-- FROM -->

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/post_source_card"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Pickup Location"
                        app:boxBackgroundColor="?attr/colorSurface"
                        app:boxCornerRadiusBottomEnd="22dp"
                        app:boxCornerRadiusBottomStart="22dp"
                        app:boxCornerRadiusTopEnd="22dp"
                        app:boxCornerRadiusTopStart="22dp"
                        app:startIconDrawable="@drawable/ic_location_on">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/p_source"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_medium"
                            android:inputType="textCapWords"
                            android:paddingVertical="18dp"
                            android:textColor="?attr/colorOnSurface"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- TO -->

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/post_destination_card"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:hint="Destination"
                        app:boxBackgroundColor="?attr/colorSurface"
                        app:boxCornerRadiusBottomEnd="22dp"
                        app:boxCornerRadiusBottomStart="22dp"
                        app:boxCornerRadiusTopEnd="22dp"
                        app:boxCornerRadiusTopStart="22dp"
                        app:startIconDrawable="@drawable/ic_route">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/p_destination"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_medium"
                            android:inputType="textCapWords"
                            android:paddingVertical="18dp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- PRICE -->

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/post_amount_card"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:hint="Price Per Seat"
                        app:boxBackgroundColor="?attr/colorSurface"
                        app:boxCornerRadiusBottomEnd="22dp"
                        app:boxCornerRadiusBottomStart="22dp"
                        app:boxCornerRadiusTopEnd="22dp"
                        app:boxCornerRadiusTopStart="22dp"
                        app:startIconDrawable="@drawable/ic_currency_rupee">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/p_ammount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_medium"
                            android:inputType="number"
                            android:paddingVertical="18dp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- SEATS -->

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/post_seats_card"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:hint="Available Seats"
                        app:boxBackgroundColor="?attr/colorSurface"
                        app:boxCornerRadiusBottomEnd="22dp"
                        app:boxCornerRadiusBottomStart="22dp"
                        app:boxCornerRadiusTopEnd="22dp"
                        app:boxCornerRadiusTopStart="22dp"
                        app:startIconDrawable="@drawable/ic_group">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/p_seats"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_medium"
                            android:inputType="number"
                            android:paddingVertical="18dp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- DATE -->

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/post_date_card"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:hint="Departure Date"
                        app:boxBackgroundColor="?attr/colorSurface"
                        app:boxCornerRadiusBottomEnd="22dp"
                        app:boxCornerRadiusBottomStart="22dp"
                        app:boxCornerRadiusTopEnd="22dp"
                        app:boxCornerRadiusTopStart="22dp"
                        app:startIconDrawable="@drawable/ic_calendar">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/p_date"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:fontFamily="@font/poppins_medium"
                            android:paddingVertical="18dp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- BUTTON -->

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/pv_post"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="28dp"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="Publish Ride"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        app:backgroundTint="?attr/colorPrimary"
                        app:cornerRadius="20dp"
                        app:elevation="0dp"
                        app:icon="@drawable/ic_post_add"
                        app:iconGravity="textStart"
                        app:iconPadding="12dp"
                        app:iconTint="?attr/colorOnPrimary"
                        app:rippleColor="?attr/colorPrimaryContainer"
                        android:textColor="@color/primary"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- INFO CARD -->

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tipsCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                app:cardBackgroundColor="?attr/colorSecondaryContainer"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/mainCard">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@drawable/ic_work"
                        app:tint="?attr/colorPrimary"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_semibold"
                            android:text="Travel Smart"
                            android:textColor="?attr/colorOnSecondaryContainer"
                            android:textSize="15sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/poppins_regular"
                            android:text="Post rides between Rewa, Bhopal, Indore &amp; more."
                            android:textColor="?attr/colorOnSecondaryContainer"
                            android:textSize="13sp"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceContainer"
        app:itemIconTint="@color/bottom_nav_selector"
        app:itemTextColor="@color/bottom_nav_selector"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu"/>

</androidx.constraintlayout.widget.ConstraintLayout>